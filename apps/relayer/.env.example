# Network the keeper operates on: 'sepolia' (default, safe) or 'celo' (mainnet).
RELAYER_NETWORK=sepolia

# Optional RPC override. Defaults to the public forno endpoint for the network.
RELAYER_RPC_URL=

# The ERC-8004 relayer agent's signing key. REQUIRED only when DRY_RUN=false.
# On mainnet this is the registered protocol agent (agentId 9144). Never commit it.
RELAYER_PRIVATE_KEY=

# Shared secret configured on the GitHub webhook (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=

# Safety switch. true = compute + log every action but DO NOT broadcast (no key needed).
# Set to false (and provide RELAYER_PRIVATE_KEY) to let the keeper sign transactions.
DRY_RUN=true

# HTTP port for the webhook + health server.
PORT=8787

# How often the keeper heartbeat scans for stakes to settle / bounties to cancel.
KEEPER_INTERVAL_MS=300000

# Block to start scanning PRSubmitted logs from. Set to the Core deploy block on
# mainnet to keep webhook lookups fast; 0 is fine for testnet.
EVENTS_FROM_BLOCK=0
